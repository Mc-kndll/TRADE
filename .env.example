IB_HOST=127.0.0.1
IB_PORT=7497
IB_CLIENT_ID=17

# Comma-separated list. Leave blank to accept the first managed paper account.
IB_ACCOUNT=
PAPER_ACCOUNT_ONLY=true

# Start safely. Change both values only after --once testing succeeds.
DRY_RUN=true
AUTO_TRADING_ENABLED=false

WATCHLIST=ARM,NVDA,AMD,TSLA,META,AAPL,MSFT,AMZN,QQQ,SPY
BAR_SIZE=10 mins
HISTORY_DURATION=5 D
SCAN_INTERVAL_SECONDS=60
USE_RTH=true
MARKET_DATA_TYPE=3

RISK_PER_TRADE=0.005
MAX_POSITION_VALUE_PCT=0.20
MAX_OPEN_POSITIONS=3
MAX_DAILY_LOSS_PCT=0.02
ATR_STOP_MULTIPLIER=1.5
REWARD_RISK_RATIO=2.0
MIN_SIGNAL_SCORE=80

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DATABASE_PATH=tradebot.db
LOG_LEVEL=INFO
